# Copy this file to .env for local development.
# Do not commit real passwords or machine-specific credentials.

LOCAL_DEALS_DATASOURCE_URL=jdbc:mysql://localhost:3306/local_deals?useSSL=false&serverTimezone=UTC&createDatabaseIfNotExist=true
LOCAL_DEALS_DATASOURCE_USERNAME=root
LOCAL_DEALS_DATASOURCE_PASSWORD=change-me

LOCAL_DEALS_REDIS_HOST=localhost
LOCAL_DEALS_REDIS_PORT=6379
LOCAL_DEALS_REDIS_PASSWORD=change-me

MYSQL_ROOT_PASSWORD=change-me

# Optional benchmark overrides. By default the benchmark script reuses the
# LOCAL_DEALS_* credentials above.
MYSQL_CONTAINER=local-deals-mysql
REDIS_CONTAINER=local-deals-redis
MYSQL_DATABASE=local_deals
